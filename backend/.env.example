ENVIRONMENT=development
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=true

DATABASE_URL=postgresql://multivate:multivate@localhost:5432/multivate
REDIS_URL=redis://127.0.0.1:6379/0
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/multivate
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multivate_test

SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
# PLATFORM_ADMIN_PASSWORD=  # required in production (≥12 chars)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://localhost:3002

RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
MAIL_FROM=Multivate <noreply@localhost>
MAIL_FOOTER_LINE=
MAIL_SUPPORT_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google Gemini — career guidance AI chat
GEMINI_API_KEY=

# Remita live payments (production)
REMITA_MERCHANT_ID=
REMITA_API_KEY=
REMITA_SERVICE_TYPE_ID=

# ---------------------------------------------------------------------------
# Media / file upload settings
# ---------------------------------------------------------------------------
# Root directory (relative to backend/) where uploaded files are stored on disk
UPLOAD_ROOT=media

# Base URL path at which uploads are served (must match Nginx location in production)
PUBLIC_UPLOAD_URL=/uploads

# Maximum allowed upload size in bytes (default 50 MB)
MAX_UPLOAD_SIZE=52428800

# Comma-separated allowed MIME types per category (override to tighten/extend)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif,image/svg+xml
ALLOWED_DOCUMENT_TYPES=application/pdf,application/zip,application/x-zip-compressed
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime
