# --- Runtime profile ---
# development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO
# In staging/production must be false — use Alembic migrations instead of create_all().
AUTO_CREATE_TABLES=true

# Local Postgres (start from repo root: `docker compose up -d db`)
DATABASE_URL=postgresql://multivate:multivate@localhost:5432/multivate
# Railway: use the DATABASE_URL (or private URL) variable from the linked Postgres plugin — do not commit real URLs.

# Tests use in-memory SQLite via `tests/conftest.py`; optional manual SQLite:
# DATABASE_URL=sqlite:///./multivate.db

# JWT (generate strong random strings for production; min 32 chars in staging/production)
SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (comma-separated origins; include your Next.js dev URL)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://localhost:3002
