# Runtime: development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=true

DATABASE_URL=postgresql://multivate:multivate@localhost:5432/multivate

# Signup email OTP (5 min) is stored in Redis between /register/*/start and /verify
REDIS_URL=redis://127.0.0.1:6379/0
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/multivate
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multivate_test

SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://localhost:3002

# --- Outbound email (Resend only; https://resend.com) ---
# One API key on the server. End users never paste mail passwords into your app.
# If RESEND_API_KEY is unset, development uses dev_otp / MULTIVATE_DEV_OTP logs instead of sending mail.
RESEND_API_KEY=
# Verified sender, e.g. Multivate <onboarding@resend.dev> or noreply@your-verified-domain.com
RESEND_FROM=onboarding@resend.dev
# Optional: display/mailto fallback for OTP templates when RESEND_FROM is empty (legacy env name SMTP_FROM still works)
MAIL_FROM=Multivate <noreply@localhost>

# Optional copy for OTP HTML footer / support link
MAIL_FOOTER_LINE=
MAIL_SUPPORT_URL=

# From backend/:  python scripts/test_resend.py recipient@example.com
